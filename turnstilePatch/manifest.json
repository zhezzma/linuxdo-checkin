{
  "manifest_version": 3,
  "name": "TurnstilePatch",
  "version": "1.0",
  "description": "Auto-solve Cloudflare Turnstile challenge for headless automation",
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["script.js"],
      "run_at": "document_start",
      "all_frames": true,
      "world": "MAIN"
    }
  ]
}
